{
  "name": "MADO queue",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.devcontainer.yml"
  ],
  "service": "queue",
  "workspaceFolder": "/app",
  "forwardPorts": [
    8000
  ],
  "portsAttributes": {
    "8000": {
      "label": "MADO queue",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
